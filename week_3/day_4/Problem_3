class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        int n = heights.size();
        int maxArea = 0;
        
        for (int i = 0; i < n; i++) {
            int minHeight = heights[i];
            
            for (int j = i; j < n; j++) {
                if (heights[j] < minHeight) {
                    minHeight = heights[j];
                }
                
                int width = j - i + 1;
                int currentArea = minHeight * width;
                
                if (currentArea > maxArea) {
                    maxArea = currentArea;
                }
            }
        }
        
        return maxArea;
    }
};
