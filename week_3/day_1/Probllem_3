class Solution {
public:
int getsize(ListNode* temp){
    int sz=0;
    
    while (temp!=NULL){
        temp=temp->next;
        sz++;
    }
    return sz;
}
    ListNode* middleNode(ListNode* head) {
        int size = getsize(head);
        ListNode* temp=head;
        for(int i=1;i<=(size/2);i++){
            temp=temp->next;
        }   
        return temp;  
    }
};
